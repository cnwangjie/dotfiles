{
  "mcpServers": {
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/"
    },
    "chrome-devtools": {
      "command": "bunx",
      "args": [
        "chrome-devtools-mcp@latest",
        "--no-usage-statistics"
      ]
    },
    "mcp-image": {
      "command": "bunx",
      "args": [
        "-y",
        "mcp-image"
      ],
      "env": {
        "GEMINI_API_KEY": {{ gopass "mcp/gemini-api-key" | quote }},
        "IMAGE_OUTPUT_DIR": {{ printf "%s/Workspace/mcp-image" .chezmoi.homeDir | quote }}
      }
    },
    "buffer": {
      "type": "http",
      "url": "https://mcp.buffer.com/mcp"
    }
  }
}
