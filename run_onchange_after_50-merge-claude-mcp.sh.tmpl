#!/usr/bin/env bash
# Re-runs whenever the intent file's content changes (hash below makes the
# rendered script differ, which is what chezmoi's run_onchange_ tracks).
# intent-hash: {{ include "dot_claude/mcp-servers.json" | sha256sum }}

set -euo pipefail

INTENT="$HOME/.claude/mcp-servers.json"
TARGET="$HOME/.claude.json"

[ -f "$INTENT" ] || { echo "merge-claude-mcp: intent file missing, skipping" >&2; exit 0; }
command -v jq >/dev/null || { echo "merge-claude-mcp: jq not installed, skipping" >&2; exit 0; }

if [ ! -f "$TARGET" ]; then
  jq '{mcpServers: .mcpServers}' "$INTENT" > "$TARGET"
  echo "merge-claude-mcp: created $TARGET"
  exit 0
fi

tmp=$(mktemp)
jq --slurpfile intent "$INTENT" '.mcpServers = $intent[0].mcpServers' "$TARGET" > "$tmp"

if ! cmp -s "$TARGET" "$tmp"; then
  mv "$tmp" "$TARGET"
  echo "merge-claude-mcp: updated .mcpServers in $TARGET"
else
  rm -f "$tmp"
fi
